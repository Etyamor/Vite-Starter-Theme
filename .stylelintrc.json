{
  "extends": "stylelint-config-standard",
  "rules": {
    "import-notation": null,
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["theme", "plugin", "source", "utility", "variant", "custom-variant", "apply", "layer", "config", "tailwind", "screen"]
      }
    ],
    "function-no-unknown": [
      true,
      {
        "ignoreFunctions": ["theme"]
      }
    ]
  }
}
